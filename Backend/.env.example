# Guardian AI — Backend Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=pda
PGUSER=postgres
PGPASSWORD=

# Authentication
JWT_SECRET=your_jwt_secret_here

# AI Chat (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Server
PORT=8000
